diff -Naur old_extract/gcc-12.2.0/gcc/config.gcc new_workspace/gcc-12.2.0/gcc/config.gcc
--- a/gcc/config.gcc	2022-08-19 03:09:52.552662114 -0500
+++ b/gcc/config.gcc	2026-07-12 16:46:32.023340430 -0500
@@ -773,6 +773,14 @@
   tmake_file="${tmake_file} t-dragonfly"
   target_has_targetdm=yes
   ;;
+*-*-boredos*)
+  extra_options="$extra_options gnu-user.opt"
+  gas=yes
+  gnu_ld=yes
+  default_use_cxa_atexit=yes
+  use_gcc_stdint=provide
+  thread_file='posix'
+  ;;
 *-*-freebsd*)
   # This is the generic ELF configuration of FreeBSD.  Later
   # machine-specific sections may refine and add to this
@@ -1901,6 +1909,12 @@
 x86_64-*-elf*)
 	tm_file="${tm_file} i386/unix.h i386/att.h dbxelf.h elfos.h newlib-stdint.h i386/i386elf.h i386/x86-64.h"
 	;;
+i[34567]86-*-boredos*)
+	tm_file="${tm_file} i386/unix.h i386/att.h dbxelf.h elfos.h glibc-stdint.h i386/i386elf.h boredos.h gnu-user.h"
+	;;
+x86_64-*-boredos*)
+	tm_file="${tm_file} i386/unix.h i386/att.h dbxelf.h elfos.h glibc-stdint.h i386/i386elf.h i386/x86-64.h boredos.h gnu-user.h"
+	;;
 x86_64-*-rtems*)
 	tm_file="${tm_file} i386/unix.h i386/att.h dbxelf.h elfos.h newlib-stdint.h i386/i386elf.h i386/x86-64.h i386/rtemself.h rtems.h"
 	;;
