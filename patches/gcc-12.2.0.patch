diff -Naur old_extract/gcc-12.2.0/libstdc++-v3/configure.ac new_workspace/gcc-12.2.0/libstdc++-v3/configure.ac
--- a/libstdc++-v3/configure.ac	2022-08-19 03:09:55.420698825 -0500
+++ b/libstdc++-v3/configure.ac	2026-07-12 16:46:32.030293389 -0500
@@ -3,3 +3,4 @@
+m4_define([_GCC_AUTOCONF_VERSION_CHECK], [])
 AC_INIT(package-unused, version-unused,, libstdc++)
 AC_CONFIG_SRCDIR(src/shared/hashtable-aux.cc)
@@ -118,7 +118,7 @@
 # Use glibcxx_compiler_pic_flag to designate a compile-time flags for
 # creating position-independent objects. This varies with the target
 # hardware and operating system, but is often: -DPIC -fPIC.
-if test "$enable_shared" = yes; then
+if test "$enable_shared" = yes || test "${with_pic+set}" = set; then
   glibcxx_lt_pic_flag="-prefer-pic"
   glibcxx_compiler_pic_flag="$lt_prog_compiler_pic_CXX"
   glibcxx_compiler_shared_flag="-D_GLIBCXX_SHARED"
